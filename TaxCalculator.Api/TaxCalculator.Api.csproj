    </PackageReference>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
    <PackageReference Include="Serilog.AspNetCore" Version="7.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="5.0.0" />
    <PackageReference Include="Serilog.Settings.Configuration" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TaskCalculator.Application\TaskCalculator.Application.csproj" />
    <ProjectReference Include="..\TaskCalculator.Domain\TaskCalculator.Domain.csproj" />
    <ProjectReference Include="..\TaskCalculator.Infrastructure\TaskCalculator.Infrastructure.csproj" />
  </ItemGroup>

</Project>
