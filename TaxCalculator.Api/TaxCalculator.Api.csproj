    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d91a2b90-3af9-46ff-b76b-52281656ad87</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
